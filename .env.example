# Research environment variables
# Copy this to .env and fill in your keys

# ── Alpaca (paper trading) ──────────────────────────────────────────────────
# Get keys at https://app.alpaca.markets/
# NEVER commit real API keys — use paper-only
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_PAPER=true                    # Must be true to use paper trading

# ── Data source (no key required for Yahoo Finance) ───────────────────────
DATA_SOURCE=yahoo                    # yahoo | polygon | alpaca